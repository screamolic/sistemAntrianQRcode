# Supabase Database
# Get your connection string from: https://supabase.com/dashboard/project/[your-project]/settings/database
# Use Transaction Mode connection string (with pgbouncer)
DATABASE_URL="postgresql://postgres.[your-project-ref]:[your-password]@[host].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# NextAuth - Generate secret with: openssl rand -base64 32
AUTH_SECRET="change-this-to-random-secret"
AUTH_URL="http://localhost:3000"

# Super Admin Emails (comma-separated)
SUPER_ADMIN_EMAILS="your-email@example.com"

# Evolution-API (WhatsApp Notifications)
# Optional - app works without it for testing
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="change-this-to-your-evolution-api-key"
EVOLUTION_INSTANCE_NAME="queue-automation"

# Cron Jobs
CRON_SECRET="change-this-to-random-secret"
